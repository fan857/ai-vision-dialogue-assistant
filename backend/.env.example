# ===== 火山方舟 Coding Plan 视觉模型配置 =====
# 注意：本文件是示例，真实配置请放在 backend/.env，.env 已被 .gitignore 忽略。
# 严禁将真实 API Key 提交到代码仓库。

# Coding Plan 固定端点（仅允许此端点，不自动切换到 /api/v3）
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3

# 火山方舟 Coding Plan API Key（在火山方舟控制台申请）
ARK_API_KEY=your_coding_plan_api_key_here

# 视觉模型名
ARK_MODEL=doubao-seed-2.0-pro

# 单次请求超时时间（秒）
ARK_TIMEOUT_SECONDS=60

# 模型最大输出 token 数（成本控制）
ARK_MAX_TOKENS=300

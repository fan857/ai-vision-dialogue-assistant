# ===== 火山方舟 Coding Plan 视觉模型配置 =====
# 注意：本文件是示例，真实配置请放在 backend/.env，.env 已被 .gitignore 忽略。
# 严禁将真实 API Key 提交到代码仓库。

# Coding Plan 固定端点（仅允许此端点，不自动切换到 /api/v3）
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3

# 火山方舟 Coding Plan API Key（在火山方舟控制台申请）
ARK_API_KEY=your_coding_plan_api_key_here

# 视觉模型名
ARK_MODEL=doubao-seed-2.0-pro

# 单次请求超时时间（秒）
ARK_TIMEOUT_SECONDS=60

# 模型最大输出 token 数（成本控制）
ARK_MAX_TOKENS=300

# ===== 阿里云百炼 Qwen Realtime 实时语音配置（PR8） =====
# 注意：本文件是示例，真实配置请放在 backend/.env，.env 已被 .gitignore 忽略。
# 严禁将真实 API Key 提交到代码仓库。

# DashScope（北京）API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 实时语音 WebSocket 端点
QWEN_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# 实时模型名
QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime

# TTS 声音（默认 Tina）
QWEN_REALTIME_VOICE=Tina

# ===== 视觉请求缓存与去重配置（PR9） =====
# 是否启用内存级 TTL 缓存与 in-flight 去重。
# 仅在后端进程内存中保存，服务重启后自动清空。
VISION_CACHE_ENABLED=true

# 缓存有效期（秒）。相同图片 + 相同问题在 TTL 内直接复用结果。
VISION_CACHE_TTL_SECONDS=300

# 缓存最大条目数（LRU 淘汰）。超过后清理最旧记录。
VISION_CACHE_MAX_ITEMS=100
